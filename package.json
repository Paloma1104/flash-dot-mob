{
  "name": "flash.mob",
  "description": "Turn your city into a treasure hunt. Earn crypto at real locations, powered by Monad's lightning-fast blockchain.",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --clear",
    "start:all": "concurrently --kill-others --names 'ANVIL,BACKEND,FRONTEND' --prefix-colors 'cyan,magenta,green' \"npm run blockchain\" \"npm run backend\" \"npm run dev\"",
    "start:demo": "concurrently --kill-others --names 'BACKEND,FRONTEND' --prefix-colors 'magenta,green' \"npm run backend\" \"npm run dev\"",
    "blockchain": "wsl bash -c \"cd /mnt/c/Users/LENOVO/Desktop/flash.mob/contracts && ~/.foundry/bin/anvil\"",
    "backend": "cd backend && npm run dev",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run lint",
    "test:backend": "cd backend && powershell -File test-api.ps1",
    "setup": "npm install && cd contracts && forge install && cd ..",
    "setup:full": "npm run setup && npm run contracts:build && cd backend && npm install",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test -vvv",
    "contracts:deploy:testnet": "cd contracts && forge script script/Deploy.s.sol:DeployScript --rpc-url https://testnet-rpc.monad.xyz --broadcast -vvvv",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform all",
    "build:production": "eas build --profile production --platform all",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "reset-project": "node ./scripts/reset-project.js",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean"
  },
  "dependencies": {
    "@ethersproject/shims": "^5.8.0",
    "@expo/vector-icons": "^15.0.3",
    "@privy-io/expo": "^0.63.1",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@rnmapbox/maps": "^10.2.10",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.2.12",
    "@supabase/supabase-js": "^2.91.1",
    "@tanstack/react-query": "^5.90.17",
    "@walletconnect/ethereum-provider": "^2.23.4",
    "@walletconnect/modal": "^2.7.0",
    "expo": "~54.0.32",
    "expo-application": "~7.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.22",
    "expo-sensors": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-maps": "1.20.1",
    "react-native-maps-clustering": "^1.2.4",
    "react-native-mmkv": "^4.1.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "viem": "^2.44.4",
    "wagmi": "^3.3.2",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/react": "~19.1.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
