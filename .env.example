# Flash.Mob Environment Variables
# Copy this to .env and fill in your values

# Mapbox
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# WalletConnect (REQUIRED for wallet connections)
# Get your project ID from: https://cloud.walletconnect.com/
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Privy (for Phase 5)
EXPO_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Chain Config
EXPO_PUBLIC_CHAIN_ID=10143
EXPO_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz

# API (for Phase 6)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Sentry (Crash Reporting)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Smart Contracts (deploy and add addresses)
EXPO_PUBLIC_DROP_CLAIMER_ADDRESS=0x...
EXPO_PUBLIC_TOKEN_ADDRESS=0x...
